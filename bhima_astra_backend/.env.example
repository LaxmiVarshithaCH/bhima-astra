# ============================================================================
# BHIMA ASTRA - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit the actual .env file to GitHub
# ============================================================================

# DATABASE CONFIGURATION
# Neon PostgreSQL (https://neon.tech)
DATABASE_URL=postgresql://user:password@host.neon.tech/database

# REDIS CONFIGURATION
# Upstash Redis (https://upstash.com)
REDIS_URL=redis://:password@host:port

# SECURITY
# Generate with: openssl rand -hex 32
SECRET_KEY=your-random-secret-key-here-change-in-production

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS Origins (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ENVIRONMENT
# Options: development, staging, production
ENVIRONMENT=development

# ============================================================================
# OPTIONAL: External API Keys
# ============================================================================

# Razorpay (Sandbox/Live)
# RAZORPAY_KEY_ID=your-key-id
# RAZORPAY_KEY_SECRET=your-key-secret

# Anthropic Claude (for fraud LLM agent)
# ANTHROPIC_API_KEY=your-api-key

# ============================================================================
# OPTIONAL: Feature Flags
# ============================================================================

# SMS Provider (mock, twilio, sns)
SMS_PROVIDER=mock

# Payment Provider (mock, razorpay, stripe)
PAYMENT_PROVIDER=mock

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
# For Render Deployment:
# 1. Create Neon database at https://neon.tech (free tier)
# 2. Create Upstash Redis at https://upstash.com (free tier)
# 3. Add these env vars in Render Dashboard > Environment
# 4. Set ENVIRONMENT=production in Render
# 5. Deploy with: git push
# ============================================================================
